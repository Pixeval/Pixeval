    "version": "0.2.0",
    "configurations": [
        {
            "name": "Uno (net10.0-desktop)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/Pixeval.Experimental.Uno/bin/Debug/net10.0-desktop/Pixeval.Experimental.Uno.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Pixeval.Experimental.Uno",
            "stopAtEntry": false,
            "serverReadyAction": {
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "{0}",
                "action": "openExternally"
            }
        },
        {
            "name": "Uno (net10.0-desktop Release)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "publish",
            "program": "${workspaceFolder}/src/Pixeval.Experimental.Uno/bin/Release/net10.0-desktop/Pixeval.Experimental.Uno.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Pixeval.Experimental.Uno",
            "stopAtEntry": false,
            "serverReadyAction": {
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "{0}",
                "action": "openExternally"
            }
        }
    ]
}