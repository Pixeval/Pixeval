<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<LangVersion>preview</LangVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<IsAotCompatible>true</IsAotCompatible>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
		<EnableMcp Condition="'$(EnableMcp)' == ''">true</EnableMcp>
		<DefineConstants Condition="'$(EnableMcp)' == 'true'">$(DefineConstants);PIXEVAL_MCP</DefineConstants>
		
		<Version>5.0.1.0</Version>
		<AssemblyVersion>$(Version)</AssemblyVersion>
		<FileVersion>$(Version)</FileVersion>
		<InformationalVersion>$(Version)</InformationalVersion>
	</PropertyGroup>

	<!-- EnableMcp controls this GUI project only; dependencies must not be rebuilt with a second global-property set. -->
	<ItemDefinitionGroup>
		<ProjectReference>
			<GlobalPropertiesToRemove>EnableMcp</GlobalPropertiesToRemove>
		</ProjectReference>
	</ItemDefinitionGroup>

	<ItemGroup>
		<AvaloniaResource Include="Assets\**" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia" Version="$(AvaloniaVersion)" />
		<PackageReference Include="Avalonia.AvaloniaEdit" Version="12.0.0" />
		<PackageReference Include="Avalonia.Controls.WebView" Version="12.0.1" />
		<PackageReference Include="Avalonia.Themes.Fluent" Version="$(AvaloniaVersion)" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="$(AvaloniaVersion)" />
		<PackageReference Include="Avalonia.Controls.ColorPicker" Version="$(AvaloniaVersion)" />
		<!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
		<PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.3">
			<IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
			<PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
		</PackageReference>
		
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Markdown.Avalonia" Version="12.0.0-a3" />
		<PackageReference Include="SharpYaml" Version="3.13.0" />
		<!--<PackageReference Include="SmoothScroll.Avalonia" Version="12.0.0.12" />-->
		<PackageReference Include="sqlite-net-pcl" Version="1.11.285" />
		<PackageReference Include="Svg.Controls.Skia.Avalonia" Version="12.0.0.13" />
		<PackageReference Include="TabView.Avalonia" Version="1.0.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\lib\AutoSettingsPage\AutoSettingsPage.Avalonia\AutoSettingsPage.Avalonia.csproj" />
		<ProjectReference Include="..\lib\AutoSettingsPage\AutoSettingsPage\AutoSettingsPage.csproj" />
		<ProjectReference Include="..\lib\AnimatedControls.Avalonia\AnimatedControls.Avalonia\AnimatedControls.Avalonia.csproj" />
		<ProjectReference Include="..\lib\FluentAvalonia\FluentAvalonia.csproj" />
		<ProjectReference Include="..\lib\Imouto\Imouto.BooruParser\Imouto.BooruParser.csproj" />
		<ProjectReference Include="..\lib\Mako\Mako\Mako.csproj" />
		<ProjectReference Include="..\lib\SmoothScroll.Avalonia\src\SmoothScroll.Avalonia.Controls\SmoothScroll.Avalonia.Controls.csproj" />
		<ProjectReference Include="..\Pixeval.Mcp\Pixeval.Mcp.csproj" Condition="'$(EnableMcp)' == 'true'" />
		<ProjectReference Include="..\Pixeval.I18N\Pixeval.I18N.csproj" />
		<!--<ProjectReference Include="..\Pixeval.Caching\Pixeval.Caching.csproj" />-->
		<ProjectReference Include="..\Pixeval.Download\Pixeval.Download.csproj" />
		<ProjectReference Include="..\Pixeval.Filters\Pixeval.Filters.csproj" />
		<ProjectReference Include="..\Pixeval.SourceGen\Pixeval.SourceGen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="False" />
	</ItemGroup>

	<ItemGroup Condition="'$(EnableMcp)' != 'true'">
		<AvaloniaXaml Remove="Views\Settings\McpHelpSection.axaml" />
		<Compile Remove="AppManagement\IPixevalMcpService.cs" />
		<Compile Remove="AppManagement\McpSettingsGroup.cs" />
		<Compile Remove="Models\McpServer\**\*.cs" />
		<Compile Remove="Views\Settings\McpHelpSection.Mcp.cs" />
		<Compile Remove="Views\Settings\McpHelpSection.McpTools.cs" />
	</ItemGroup>

	<ItemGroup>
		<!-- 字符串资源相关 -->
		<AdditionalFiles Include="i18n\**\*.json" />
		<AdditionalFiles Include="Views\**\*.axaml" />
		<AdditionalFiles Include="Assets\PathIcons\*.svg" />

		<None Update="i18n\**\*.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="i18n\**\*.md">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>

		<None Update="i18n\Language.tt">
			<Generator>TextTemplatingFileGenerator</Generator>
			<LastGenOutput>Language.cs</LastGenOutput>
		</None>

		<Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />

		<Compile Update="i18n\Language.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Language.tt</DependentUpon>
		</Compile>
	</ItemGroup>
</Project>
