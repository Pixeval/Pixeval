<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval"
    xmlns:controls1="clr-namespace:Pixeval.Controls">

    <Design.PreviewWith>
        <StackPanel Width="400" Spacing="10">
            <StackPanel Background="{DynamicResource SystemRegionBrush}">
                <controls1:DigitalSignalItem />
            </StackPanel>
        </StackPanel>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type controls1:DigitalSignalItem}" TargetType="{x:Type controls1:DigitalSignalItem}">
        <Setter Property="Template">
            <ControlTemplate>
                <DockPanel HorizontalSpacing="5">
                    <Ellipse
                        Width="7"
                        Height="7"
                        Fill="{TemplateBinding Fill}" />
                    <TextBlock
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{TemplateBinding Text}"
                        Theme="{StaticResource CaptionTextBlockStyle}" />
                </DockPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
