<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls">
    <ControlTheme x:Key="{x:Type controls:UserBasicInfoPresenter}" TargetType="{x:Type controls:UserBasicInfoPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:UserBasicInfoPresenter}">
                    <DockPanel MinHeight="52" HorizontalSpacing="10">
                        <controls:AvatarImage
                            Width="42"
                            Height="42"
                            VerticalAlignment="Center"
                            controls:Source.Cache="{Binding AvatarUrl, RelativeSource={RelativeSource TemplatedParent}}"
                            DockPanel.Dock="Left" />
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding UserDisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding AccountDisplay, RelativeSource={RelativeSource TemplatedParent}}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
