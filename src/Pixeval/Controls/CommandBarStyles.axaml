<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="CommandBarButton[IsCompact=True]">
        <Setter Property="ToolTip.Tip" Value="{Binding $self.Label}" />
    </Style>

    <Style Selector="CommandBarToggleButton[IsCompact=True]">
        <Setter Property="ToolTip.Tip" Value="{Binding $self.Label}" />
    </Style>

    <Style Selector="CommandBarButton[IsInOverflow=True] /template/ ContentPresenter#PART_IconPresenter">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
    </Style>

    <Style Selector="CommandBarToggleButton[IsInOverflow=True] /template/ ContentPresenter#PART_IconPresenter">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
    </Style>

    <Style Selector="CommandBarButton:disabled">
        <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
    </Style>

    <Style Selector="CommandBarToggleButton:disabled">
        <Setter Property="Foreground" Value="{DynamicResource ToggleButtonForegroundDisabled}" />
    </Style>

</Styles>
