<views:IconContentPage
    x:Class="Pixeval.Views.HistoryPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:Mako.Global.Enum"
    xmlns:markup1="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Pixeval.Views"
    xmlns:work="using:Pixeval.Views.Work"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <work:WorkContainer x:Name="WorkContainer">
        <work:WorkContainer.CommandBarElements>
            <controls:SymbolComboBox
                x:Name="SimpleWorkTypeComboBox"
                ItemsSource="{markup1:EnumResources x:TypeArguments=enum:SimpleWorkType}"
                SelectedValue="{x:Static views:PixevalSettings.SimpleWorkType}"
                SelectionChanged="SimpleWorkTypeComboBox_OnSelectionChanged" />
        </work:WorkContainer.CommandBarElements>
    </work:WorkContainer>
</views:IconContentPage>
