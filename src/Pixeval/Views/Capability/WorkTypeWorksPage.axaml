<ContentPage
    x:Class="Pixeval.Views.Capability.WorkTypeWorksPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:views="using:Pixeval.Views"
    xmlns:work="using:Pixeval.Views.Work"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <work:WorkContainer x:Name="WorkContainer" RefreshRequested="WorkContainer_OnRefreshRequested">
        <work:WorkContainer.CommandBarElements>
            <controls:SymbolComboBox
                x:Name="WorkTypeComboBox"
                ItemsSource="{x:Static utilities:WorkTypeExtension.Items}"
                SelectedIndex="{x:Static views:PixevalSettings.WorkTypeIndex}"
                SelectionChanged="WorkTypeComboBox_OnSelectionChanged" />
        </work:WorkContainer.CommandBarElements>
    </work:WorkContainer>
</ContentPage>
