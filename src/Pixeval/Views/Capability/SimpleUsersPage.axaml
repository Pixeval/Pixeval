<ContentPage
    x:Class="Pixeval.Views.Capability.SimpleUsersPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entry="using:Pixeval.Views.Entry"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <entry:UserContainer x:Name="UserContainer" RefreshRequested="UserContainer_OnRefreshRequested" />
</ContentPage>
