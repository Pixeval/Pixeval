<UserControl
    x:Class="Pixeval.Views.Capability.FollowingsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entry="using:Pixeval.Views.Entry"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utilities="using:Pixeval.Utilities"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <entry:UserContainer x:Name="UserContainer" RefreshRequested="UserContainer_OnRefreshRequested">
        <entry:UserContainer.CommandBarElements>
            <controls:SymbolComboBox
                x:Name="PrivacyPolicyComboBox"
                ItemsSource="{x:Static utilities:PrivacyPolicyExtension.Items}"
                SelectionChanged="WorkTypeComboBox_OnSelectionChanged" />
        </entry:UserContainer.CommandBarElements>
    </entry:UserContainer>
</UserControl>
