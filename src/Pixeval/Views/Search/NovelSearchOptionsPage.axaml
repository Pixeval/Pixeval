<ContentPage
    x:Class="Pixeval.Views.Search.NovelSearchOptionsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:Mako.Global.Enum"
    xmlns:markup="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:viewModels="using:Pixeval.ViewModels.Search"
    x:DataType="{x:Type viewModels:NovelSearchFormViewModel}"
    DataContext="{x:Null}"
    Header="{I18N {x:Static pixeval:SearchResources.AdvancedOptionsNovelTab}}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <StackPanel Margin="12" Spacing="12">
        <TextBlock FontWeight="SemiBold" Text="{I18N {x:Static pixeval:SearchResources.SectionsCommon}}" />
        <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonSortOption}}" />
            <controls:SymbolComboBox
                Grid.Column="1"
                IconMode="False"
                ItemsSource="{markup:EnumResources x:TypeArguments=enum:WorkSortOption}"
                SelectedValue="{Binding SortOption, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonStartDate}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartDateOption.IsEnabled, Mode=TwoWay}" />
            <CalendarDatePicker
                Grid.Column="2"
                IsEnabled="{Binding StartDateOption.IsEnabled}"
                SelectedDate="{Binding StartDateOption.Value, Mode=TwoWay}"
                SelectedDateFormat="Short" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonEndDate}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding EndDateOption.IsEnabled, Mode=TwoWay}" />
            <CalendarDatePicker
                Grid.Column="2"
                IsEnabled="{Binding EndDateOption.IsEnabled}"
                SelectedDate="{Binding EndDateOption.Value, Mode=TwoWay}"
                SelectedDateFormat="Short" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonShowAiWorks}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AiType, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonMergePlainKeywordResults}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding MergePlainKeywordResults, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonIncludeTranslatedTagResults}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IncludeTranslatedTagResults, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.CommonIncludePotentialViolationWorks}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IncludePotentialViolationWorks, Mode=TwoWay}" />
        </Grid>

        <Separator />

        <TextBlock FontWeight="SemiBold" Text="{I18N {x:Static pixeval:SearchResources.SectionsNovel}}" />
        <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelMatchOption}}" />
            <controls:SymbolComboBox
                Grid.Column="1"
                IconMode="False"
                ItemsSource="{markup:EnumResources x:TypeArguments=enum:SearchNovelTagMatchOption}"
                SelectedValue="{Binding MatchOption, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelLanguage}}" />
            <ComboBox
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                DisplayMemberBinding="{Binding Name}"
                ItemsSource="{Binding LanguageItems}"
                SelectedIndex="0"
                SelectedValue="{Binding Language, Mode=TwoWay, TargetNullValue=''}"
                SelectedValueBinding="{Binding Code}" />
        </Grid>
        <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelContentLengthOption}}" />
            <controls:SymbolComboBox
                Grid.Column="1"
                IconMode="False"
                ItemsSource="{markup:EnumResources x:TypeArguments=enum:SearchNovelContentLengthOption}"
                SelectedValue="{Binding ContentLengthOption, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelContentLengthMin}}" />
            <ToggleSwitch
                Grid.Column="1"
                IsChecked="{Binding ContentLengthMinOption.IsEnabled, Mode=TwoWay}"
                IsEnabled="{Binding IsContentLengthEnabled}" />
            <NumericUpDown
                Grid.Column="2"
                AllowSpin="True"
                ClipValueToMinMax="True"
                FormatString="F0"
                Increment="1"
                IsEnabled="{Binding IsContentLengthEnabled}"
                Minimum="0"
                Value="{Binding ContentLengthMinOption.Value, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelContentLengthMax}}" />
            <ToggleSwitch
                Grid.Column="1"
                IsChecked="{Binding ContentLengthMaxOption.IsEnabled, Mode=TwoWay}"
                IsEnabled="{Binding IsContentLengthEnabled}" />
            <NumericUpDown
                Grid.Column="2"
                AllowSpin="True"
                ClipValueToMinMax="True"
                FormatString="F0"
                Increment="1"
                IsEnabled="{Binding IsContentLengthEnabled}"
                Minimum="0"
                Value="{Binding ContentLengthMaxOption.Value, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelIsOriginalOnly}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsOriginalOnly, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelGenre}}" />
            <ComboBox
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                DisplayMemberBinding="{Binding Label}"
                IsEnabled="{Binding IsOriginalOnly}"
                ItemsSource="{Binding GenreItems}"
                SelectedIndex="0"
                SelectedValue="{Binding GenreId, Mode=TwoWay}"
                SelectedValueBinding="{Binding Id}" />
        </Grid>
        <Grid ColumnDefinitions="180,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center" Text="{I18N {x:Static pixeval:SearchResources.NovelIsReplaceableOnly}}" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsReplaceableOnly, Mode=TwoWay}" />
        </Grid>
    </StackPanel>
</ContentPage>
