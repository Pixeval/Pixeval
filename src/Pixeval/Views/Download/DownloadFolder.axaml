<UserControl
    x:Class="Pixeval.Views.Download.DownloadFolder"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:markup="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Pixeval.ViewModels"
    x:DataType="{x:Type viewModels:DownloadFolderViewModel}"
    HorizontalAlignment="Stretch"
    mc:Ignorable="d"
    d:DesignHeight="90"
    d:DesignWidth="800">
    <Button
        Margin="8"
        Padding="12"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        Click="Button_OnClicked"
        CornerRadius="8">
        <Grid
            HorizontalAlignment="Stretch"
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="12">
            <fluent:SymbolIcon
                Grid.Column="0"
                Width="32"
                Height="32"
                VerticalAlignment="Center"
                Symbol="FolderSync" />
            <fluent:SymbolIcon
                Grid.Column="2"
                VerticalAlignment="Center"
                Symbol="ChevronRight" />
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="{Binding Title}"
                    TextTrimming="CharacterEllipsis" />
                <ProgressBar Maximum="100" Value="{Binding ProgressPercentage}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock
                        Grid.Column="0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Subtitle}"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="5">
                        <controls:DigitalSignalItem
                            Fill="{markup:BindingDynamicResource {Binding StateBrushKey}}"
                            IsVisible="{Binding !!ActiveCount}"
                            Text="{Binding ActiveCount}" />
                        <controls:DigitalSignalItem
                            Fill="{DynamicResource SystemFillColorSuccessBrush}"
                            IsVisible="{Binding !!CompletedCount}"
                            Text="{Binding CompletedCount}" />
                        <controls:DigitalSignalItem
                            Fill="{DynamicResource SystemFillColorCriticalBrush}"
                            IsVisible="{Binding !!ErrorCount}"
                            Text="{Binding ErrorCount}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Button>
</UserControl>
