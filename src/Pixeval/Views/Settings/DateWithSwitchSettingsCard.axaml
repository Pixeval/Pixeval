
<controls:SettingsCard
    x:Class="Pixeval.Views.Settings.DateWithSwitchSettingsCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:am="using:Pixeval.AppManagement"
    xmlns:avalonia="using:AutoSettingsPage.Avalonia"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entries="using:Pixeval.Models.Settings.Entries"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="{x:Type entries:DateWithSwitchSettingsEntry,
                        x:TypeArguments=am:AppSettings}"
    Description="{Binding Converter={x:Static avalonia:SettingsEntryHelper.DescriptionConverter}}"
    Header="{Binding Header}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <controls:SettingsCard.HeaderIcon>
        <fluent:SymbolIcon Symbol="{Binding Icon}" />
    </controls:SettingsCard.HeaderIcon>
    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
        <ToggleSwitch Grid.Column="0" IsChecked="{Binding Value, Mode=TwoWay}" />
        <CalendarDatePicker
            x:Name="CalendarDatePicker"
            Grid.Column="1"
            MinWidth="150"
            DisplayDateEnd="{Binding DateEntry.Max}"
            DisplayDateStart="{Binding DateEntry.Min}"
            IsEnabled="{Binding Value}"
            PlaceholderText="{Binding Placeholder}"
            SelectedDate="{Binding DateEntry.Value, Mode=TwoWay}" />
    </Grid>
</controls:SettingsCard>
