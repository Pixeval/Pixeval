<controls:SettingsExpander
    x:Class="Pixeval.Views.Settings.DownloadMacroSettingsExpander"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="using:AutoSettingsPage.Avalonia"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:controls2="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entries="using:Pixeval.Models.Settings.Entries"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:utilities="using:Pixeval.Utilities"
    x:DataType="{x:Type entries:DownloadMacroAppSettingsEntry}"
    Description="{Binding Converter={x:Static avalonia:SettingsEntryHelper.DescriptionConverter}}"
    Header="{Binding Header}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <controls:SettingsExpander.HeaderIcon>
        <fluent:SymbolIcon Symbol="{Binding Icon}" />
    </controls:SettingsExpander.HeaderIcon>
    <controls:SettingsExpander.Items>
        <controls:SettingsCard ContentAlignment="Left">
            <StackPanel Spacing="3">
                <ItemsControl ItemsSource="{x:Static entries:DownloadMacroAppSettingsEntry.AvailableMacros}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemSpacing="5" LineSpacing="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="{x:Type controls2:SymbolComboBoxItem}">
                            <Button
                                Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                                Content="{Binding Value}"
                                Tag="{Binding Value}"
                                ToolTip.Tip="{I18N Key={Binding Value}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox
                    x:Name="DownloadPathMacroTextBox"
                    AcceptsReturn="False"
                    PlaceholderText="{I18N {x:Static pixeval:SettingsMainViewResources.DownloadPathMacroTextBoxPlaceholderText}}"
                    Text="{Binding Value, Mode=OneTime}"
                    TextChanged="DownloadPathMacroTextBox_OnTextChanged" />
                <TextBlock>
                    <Run Text="{I18N {x:Static pixeval:SettingsMainViewResources.SinglePathBlockText}}" />
                    <Run x:Name="SinglePathBlock" />
                    <LineBreak />
                    <Run Text="{I18N {x:Static pixeval:SettingsMainViewResources.AnimatedPathBlockText}}" />
                    <Run x:Name="AnimatedPathBlock" />
                    <LineBreak />
                    <Run Text="{I18N {x:Static pixeval:SettingsMainViewResources.SetPathBlockText}}" />
                    <Run x:Name="SetPathBlock" />
                    <LineBreak />
                    <Run Text="{I18N {x:Static pixeval:SettingsMainViewResources.NovelPathBlockText}}" />
                    <Run x:Name="NovelPathBlock" />
                    <LineBreak />
                </TextBlock>
                <TextBlock
                    Foreground="Red"
                    IsVisible="{Binding #DownloadMacroInvalidInfoBar.IsVisible}"
                    Text="{I18N {x:Static pixeval:SettingsMainViewResources.DownloadMacroInvalidInfoBarTitle}}" />
                <TextBlock
                    x:Name="DownloadMacroInvalidInfoBar"
                    Foreground="Red"
                    IsVisible="False" />
            </StackPanel>
        </controls:SettingsCard>
    </controls:SettingsExpander.Items>
</controls:SettingsExpander>
