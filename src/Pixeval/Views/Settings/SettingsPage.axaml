<UserControl
    x:Class="Pixeval.Views.Settings.SettingsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FluentAvalonia.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Pixeval.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type viewModels:SettingsPageViewModel}"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <viewModels:SettingsPageViewModel />
    </UserControl.DataContext>
    <controls:Frame x:Name="Frame" Margin="50" />
</UserControl>
