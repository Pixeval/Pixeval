<NavigationPage
    x:Class="Pixeval.Views.Settings.SettingsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:viewModels="using:Pixeval.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type viewModels:SettingsPageViewModel}"
    Header="{I18N {x:Static pixeval:MainPageResources.SettingsTabContent}}"
    Icon="{markup:SymbolIcon Settings,
                             FontSize=16,
                             IconVariant=Color}"
    mc:Ignorable="d">
    <NavigationPage.DataContext>
        <viewModels:SettingsPageViewModel />
    </NavigationPage.DataContext>
</NavigationPage>
