<entry:EntryItem
    x:Class="Pixeval.Views.Entry.SpotlightItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:converters="using:Pixeval.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:entry="using:Pixeval.Views.Entry"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Pixeval.ViewModels"
    x:DataType="{x:Type viewModels:SpotlightItemViewModel}"
    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
    Theme="{StaticResource RoundedButtonStyle}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <DockPanel>
        <Grid
            Margin="20"
            ColumnDefinitions="Auto,*,Auto"
            DockPanel.Dock="Bottom"
            RowDefinitions="Auto,Auto"
            RowSpacing="10">
            <ContentControl
                Grid.Row="0"
                Grid.Column="0"
                Padding="5,0"
                Background="{Binding Entry.Category, Converter={x:Static entry:SpotlightItem.BackgroundBrushConverter}}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                DockPanel.Dock="Left">
                <TextBlock Text="{Binding Entry.SubcategoryLabel}" />
            </ContentControl>
            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                DockPanel.Dock="Right"
                Foreground="DarkGray"
                Text="{Binding Entry.PublishDate, Converter={x:Static converters:PixevalConverters.DateTimeShortDate}}" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                DockPanel.Dock="Bottom"
                MaxLines="1"
                Text="{Binding Entry.Title}"
                TextTrimming="WordEllipsis"
                Theme="{StaticResource BodyLargeStrongTextBlockStyle}" />
        </Grid>
        <Image controls:Source.Cache="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
    </DockPanel>
</entry:EntryItem>
