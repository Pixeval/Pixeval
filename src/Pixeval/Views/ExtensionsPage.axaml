<views:IconContentPage
    x:Class="Pixeval.Views.ExtensionsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:converters="using:Pixeval.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="using:Pixeval.Models.Extensions"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:views="using:Pixeval.Views"
    mc:Ignorable="d"
    d:DesignHeight="800"
    d:DesignWidth="600">
    <DockPanel>
        <StackPanel
            Margin="20"
            DockPanel.Dock="Top"
            Orientation="Horizontal"
            Spacing="20">
            <TextBlock Text="{I18N {x:Static pixeval:ExtensionsPageResources.TitleTextBlockText}}" Theme="{StaticResource TitleTextBlockStyle}" />
            <TextBlock VerticalAlignment="Bottom" Theme="{StaticResource SubtitleTextBlockStyle}">
                <Run Text="{I18N {x:Static pixeval:ExtensionsPageResources.SubtitleTextBlockText}}" />
                <Run Text="{x:Static extensions:ExtensionService.CurrentVersion}" />
            </TextBlock>
        </StackPanel>
        <CommandBar
            DefaultLabelPosition="Right"
            DockPanel.Dock="Top"
            IsDynamicOverflowEnabled="True">
            <CommandBarButton
                Click="AddExtensionsOnClick"
                Icon="{markup:SymbolIcon PlugConnectedAdd}"
                Label="{I18N {x:Static pixeval:ExtensionsPageResources.AddExtensionsButtonLabel}}" />
            <CommandBarButton
                Click="OpenExtensionsOnClick"
                Icon="{markup:SymbolIcon FolderAdd}"
                Label="{I18N {x:Static pixeval:ExtensionsPageResources.OpenExtensionsButtonLabel}}" />
            <CommandBarButton
                Click="UninstallAllExtensionsOnClick"
                Icon="{markup:SymbolIcon Delete}"
                Label="{I18N {x:Static pixeval:ExtensionsPageResources.UninstallAllExtensionsButtonLabel}}" />
            <CommandBarButton
                Click="UninstallOutdatedExtensionsOnClick"
                Icon="{markup:SymbolIcon Alert}"
                Label="{I18N {x:Static pixeval:ExtensionsPageResources.UninstallOutdatedExtensionsButtonLabel}}" />
        </CommandBar>
        <ScrollViewer Margin="20,10,20,20">
            <ItemsControl ItemsSource="{Binding $parent[views:ExtensionsPage].Models}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="{x:Type extensions:ExtensionsHostModel}">
                        <controls:SettingsCard Description="{Binding Description}" HeaderIcon="{Binding Icon}">
                            <controls:SettingsCard.Header>
                                <Grid ColumnDefinitions="200,Auto" ColumnSpacing="10">
                                    <HyperlinkButton
                                        Grid.Column="0"
                                        Padding="0"
                                        HorizontalContentAlignment="Left"
                                        Content="{Binding Name}"
                                        FontWeight="Bold"
                                        NavigateUri="{Binding Link}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{Binding Author}" />
                                </Grid>
                            </controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ToggleSwitch IsChecked="{Binding IsActive, Mode=TwoWay}" />
                                <CommandBar DefaultLabelPosition="Collapsed">
                                    <CommandBarButton
                                        Click="ExtensionsPriorityUpOnClick"
                                        Icon="{markup:SymbolIcon ChevronUp}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:ExtensionsPageResources.ExtensionsPriorityUpButtonLabel}}" />
                                    <CommandBarButton
                                        Click="ExtensionsPriorityDownOnClick"
                                        Icon="{markup:SymbolIcon ChevronDown}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:ExtensionsPageResources.ExtensionsPriorityDownButtonLabel}}" />
                                    <CommandBar.SecondaryCommands>
                                        <CommandBarButton
                                            Click="ExtensionsHelpOnClick"
                                            Icon="{markup:SymbolIcon BookQuestionMark}"
                                            IsVisible="{Binding HelpLink, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Label="{I18N {x:Static pixeval:ExtensionsPageResources.ExtensionsHelpButtonLabel}}"
                                            Tag="{Binding HelpLink}" />
                                        <CommandBarButton
                                            Click="ExtensionsPriorityTopOnClick"
                                            Icon="{markup:SymbolIcon ChevronDoubleUp}"
                                            Label="{I18N {x:Static pixeval:ExtensionsPageResources.ExtensionsPriorityTopButtonLabel}}" />
                                        <CommandBarButton
                                            Click="ExtensionsPriorityBottomOnClick"
                                            Icon="{markup:SymbolIcon ChevronDoubleDown}"
                                            Label="{I18N {x:Static pixeval:ExtensionsPageResources.ExtensionsPriorityBottomButtonLabel}}" />
                                        <CommandBarButton
                                            Click="UninstallHostOnClick"
                                            Icon="{Binding UninstallCommandIcon, Converter={x:Static converters:PixevalConverters.SymbolIconConverter}}"
                                            Label="{Binding UninstallCommandLabel}" />
                                    </CommandBar.SecondaryCommands>
                                </CommandBar>
                            </StackPanel>
                        </controls:SettingsCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</views:IconContentPage>
