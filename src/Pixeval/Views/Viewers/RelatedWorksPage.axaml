<ContentPage
    x:Class="Pixeval.Views.Viewers.RelatedWorksPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:work="using:Pixeval.Views.Work"
    Background="Transparent"
    Header="{I18N {x:Static pixeval:EntryViewerPageResources.RelatedWorksTabContent}}"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="350">
    <work:WorkView x:Name="RelatedWorksView" LayoutType="VerticalStack" />
</ContentPage>
