<views:IconContentPage
    x:Class="Pixeval.Views.Viewers.WorkInfoPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:misaki="using:Misaki"
    xmlns:viewers="using:Pixeval.Views.Viewers"
    xmlns:views="using:Pixeval.Views"
    x:DataType="{x:Type misaki:IArtworkInfo}"
    Name="WorkInfoPageRoot"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="350">
    <viewers:WorkInfoPane
        ActionZone="{Binding #WorkInfoPageRoot.ActionZone}"
        ActionZoneTemplate="{Binding #WorkInfoPageRoot.ActionZoneTemplate}"
        ArtworkInfo="{Binding}" />
</views:IconContentPage>
