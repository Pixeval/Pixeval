<ContentPage
    x:Class="Pixeval.Views.Viewers.NovelViewerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:converters="using:Pixeval.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Pixeval.Views.Viewers"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:markup1="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:novel="using:Pixeval.ViewModels"
    xmlns:pixeval="using:Pixeval"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:viewers="using:Pixeval.ViewModels.Viewers"
    xmlns:work="using:Pixeval.Views.Work"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    x:DataType="{x:Type viewers:NovelViewerPageViewModel}"
    Header="{Binding CurrentNovel.Entry.Title}"
    mc:Ignorable="d">
    <ContentPage.Icon>
        <Image
            Width="16"
            Height="16"
            Source="avares://Pixeval/Assets/Platforms/pixiv.png" />
    </ContentPage.Icon>
    <ContentPage.KeyBindings>
        <KeyBinding Command="{Binding PrevCommand}" Gesture="Left" />
        <KeyBinding Command="{Binding NextCommand}" Gesture="Right" />
        <KeyBinding Command="{Binding PrevWorkCommand}" Gesture="Up" />
        <KeyBinding Command="{Binding NextWorkCommand}" Gesture="Down" />
    </ContentPage.KeyBindings>

    <Grid RowDefinitions="*,Auto,Auto">
        <SplitView
            x:Name="InfoSplitView"
            Grid.Row="0"
            DisplayMode="Inline">
            <SplitView.Pane>
                <TabbedPage Pages="{Binding PanePages}" />
            </SplitView.Pane>

            <DockPanel>
                <CommandBar
                    HorizontalAlignment="Center"
                    DefaultLabelPosition="Collapsed"
                    DockPanel.Dock="Top"
                    IsDynamicOverflowEnabled="True">
                    <CommandBarButton
                        Command="{Binding CurrentNovel.BookmarkCommand}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        Icon="{markup1:SymbolIconEx Heart,
                                                    IconVariant={Binding CurrentNovel.IsBookmarkedDisplay,
                                                                         Converter={x:Static converters:PixevalConverters.StateToIconVariant}}}"
                        IsVisible="{Binding CurrentNovel.IsBookmarkSupported}"
                        Label="{I18N {x:Static pixeval:MiscResources.AddBookmark}}" />
                    <CommandBarSeparator />
                    <CommandBarButton
                        Command="{Binding CurrentNovel.SaveCommand}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        Icon="{markup:SymbolIcon Save}"
                        Label="{I18N {x:Static pixeval:EntryViewerPageResources.Save}}" />
                    <CommandBarButton
                        Command="{Binding CurrentNovel.SaveAsCommand}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        Icon="{markup:SymbolIcon SaveEdit}"
                        Label="{I18N {x:Static pixeval:EntryViewerPageResources.SaveAs}}" />
                    <CommandBarSeparator />
                    <CommandBarButton
                        x:Name="AddToBookmarkButton"
                        Click="AddToBookmarkButton_OnClick"
                        Icon="{markup:SymbolIcon Bookmark}"
                        IsVisible="{Binding CurrentNovel.IsBookmarkSupported}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.AddToBookmark}}" />
                    <!--<CommandBarButton
                            Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                            Icon="{markup:SymbolIcon Link}"
                            Label="{I18N {x:Static pixeval:EntryItemResources.GenerateLink}}"
                            Tag="{Binding CurrentNovel.AppUri}" />-->
                    <CommandBarButton
                        Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                        Icon="{markup:SymbolIcon LinkMultiple}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.GenerateWebLink}}"
                        Tag="{Binding CurrentNovel.WebsiteUri}" />
                    <CommandBarButton
                        Click="{x:Static utilities:AvaloniaHelper.LaunchUriTagInWebBrowser}"
                        Icon="{markup:SymbolIcon GlobeArrowUp}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.OpenInWebBrowser}}"
                        Tag="{Binding CurrentNovel.WebsiteUri}" />
                </CommandBar>

                <work:TagSelector
                    x:Name="BookmarkTagSelector"
                    Margin="5"
                    DockPanel.Dock="Top"
                    IsVisible="False"
                    TagsSelected="BookmarkTagSelector_OnTagsSelected" />

                <Border Background="{Binding NovelBackgroundBrush}">
                    <Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <controls:MarkdownBox
                                MaxWidth="{Binding NovelMaxWidth}"
                                Margin="30,20"
                                Markdown="{Binding CurrentMarkdown}" />
                        </ScrollViewer>

                        <Grid Background="#7F000000" IsVisible="{Binding IsLoading}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">
                                <ProgressBar Width="160" IsIndeterminate="True" />
                                <TextBlock Foreground="White" Text="{I18N {x:Static pixeval:EntryViewerPageResources.LoadingNovelTextBlockText}}" />
                            </StackPanel>
                        </Grid>

                        <controls:PageButton
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Command="{Binding PrevCommand}"
                            IsVisible="{Binding PrevButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            RightTapped="PrevButton_OnRightClick"
                            Symbol="ChevronLeft"
                            ToolTipText="{Binding PrevButtonText}" />
                        <controls:PageButton
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Command="{Binding NextCommand}"
                            IsVisible="{Binding NextButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            RightTapped="NextButton_OnRightClick"
                            Symbol="ChevronRight"
                            ToolTipText="{Binding NextButtonText}" />
                    </Grid>
                </Border>
            </DockPanel>
        </SplitView>

        <ListBox
            Grid.Row="1"
            Height="90"
            Margin="5,0"
            Padding="0,0,0,5"
            HorizontalAlignment="Stretch"
            IsVisible="{Binding IsBottomListOpen}"
            ItemsSource="{Binding Novels}"
            SelectedIndex="{Binding CurrentWorkIndex}"
            SelectionMode="Single">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="5" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="{x:Type novel:NovelItemViewModel}">
                    <Image
                        Width="80"
                        Height="80"
                        DataContextChanged="Thumbnail_OnDataContextChanged"
                        Source="{Binding Thumbnail}"
                        Stretch="UniformToFill" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border
            Grid.Row="2"
            Height="48"
            Padding="5,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="20">
                    <CommandBar DefaultLabelPosition="Collapsed" IsDynamicOverflowEnabled="True">
                        <CommandBarToggleButton
                            Icon="{markup:SymbolIcon Info}"
                            IsChecked="{Binding #InfoSplitView.IsPaneOpen}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.InfoAndComments}}" />
                        <CommandBarToggleButton
                            Icon="{markup:SymbolIcon PanelBottomExpand}"
                            IsChecked="{Binding IsBottomListOpen}"
                            Label="{I18N {x:Static pixeval:MiscResources.OpenBottomList}}" />
                    </CommandBar>
                    <controls:IconText
                        MaxWidth="350"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        IsVisible="{Binding CurrentNovel.Entry.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Symbol="AppTitle"
                        Text="{Binding CurrentNovel.Entry.Title}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="20">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        IsVisible="{Binding IsMultiPage}">
                        <Run Text="{Binding CurrentPageIndex, Mode=OneWay, Converter={x:Static local:NovelViewerPage.PlusOneConverter}}" />
                        <Run Text="/" />
                        <Run Text="{Binding PageCount}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
