<views:IconContentPage
    x:Class="Pixeval.Views.Viewers.NovelViewerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:converters="using:Pixeval.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Pixeval.Views.Viewers"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:markup1="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:novel="using:Pixeval.ViewModels"
    xmlns:pixeval="using:Pixeval"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:viewers="using:Pixeval.ViewModels.Viewers"
    xmlns:views="using:Pixeval.Views"
    xmlns:work="using:Pixeval.Views.Work"
    x:DataType="{x:Type viewers:NovelViewerPageViewModel}"
    Header="{Binding CurrentNovel.Entry.Title, FallbackValue={x:Null}}"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="1000">
    <Grid RowDefinitions="*,Auto,Auto">
        <SplitView
            x:Name="InfoSplitView"
            Grid.Row="0"
            DisplayMode="Inline"
            IsPaneOpen="{Binding OpenWorkInfo, Source={x:Static views:PixevalSettings.Instance}, Mode=TwoWay}">
            <SplitView.Pane>
                <DockPanel>
                    <local:WorkSeriesInfoPane DataContext="{Binding SeriesInfo}" DockPanel.Dock="Bottom" />
                    <TabbedPage Pages="{Binding PanePages}" TabPlacement="Bottom" />
                </DockPanel>
            </SplitView.Pane>

            <DockPanel>
                <CommandBar
                    HorizontalAlignment="Center"
                    DefaultLabelPosition="Collapsed"
                    DockPanel.Dock="Top"
                    IsDynamicOverflowEnabled="True">
                    <CommandBarButton
                        Command="{Binding CurrentNovel.BookmarkCommand, FallbackValue={x:Null}}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        ContextRequested="AddToBookmarkButton_OnClick"
                        Icon="{markup1:SymbolIconEx Heart,
                                                    IconVariant={Binding CurrentNovel.IsBookmarkedDisplay,
                                                                         Converter={x:Static converters:PixevalConverters.StateToIconVariant}}}"
                        IsVisible="{Binding CurrentNovel.IsBookmarkSupported, FallbackValue={x:False}}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.AddToBookmark}}" />
                    <CommandBarSeparator />
                    <CommandBarButton
                        Command="{Binding CurrentNovel.SaveCommand, FallbackValue={x:Null}}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        Icon="{markup:SymbolIcon Save}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.Save}}" />
                    <CommandBarSeparator />
                    <CommandBarButton
                        Command="{Binding CurrentNovel.AddToWatchLaterCommand, FallbackValue={x:Null}}"
                        CommandParameter="{Binding $self, Mode=OneTime}"
                        Icon="{markup1:SymbolIconEx Clock,
                                                    IconVariant={Binding CurrentNovel.IsInWatchLater,
                                                                         Converter={x:Static converters:PixevalConverters.BoolToIconVariant}}}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.AddToWatchLater}}" />
                    <!--<CommandBarButton
                            Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                            Icon="{markup:SymbolIcon Link}"
                            Label="{I18N {x:Static pixeval:EntryItemResources.GenerateLink}}"
                            Tag="{Binding CurrentNovel.AppUri}" />-->
                    <CommandBarButton
                        Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                        Icon="{markup:SymbolIcon LinkMultiple}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.GenerateWebLink}}"
                        Tag="{Binding CurrentNovel.WebsiteUri, FallbackValue={x:Null}}" />
                    <CommandBarButton
                        Click="{x:Static utilities:AvaloniaHelper.LaunchUriTagInWebBrowser}"
                        Icon="{markup:SymbolIcon GlobeArrowUp}"
                        Label="{I18N {x:Static pixeval:EntryItemResources.OpenInWebBrowser}}"
                        Tag="{Binding CurrentNovel.WebsiteUri, FallbackValue={x:Null}}" />
                </CommandBar>

                <Border Background="{Binding NovelBackgroundBrush}">
                    <Panel>
                        <controls:MarkdownBox
                            MaxWidth="{Binding NovelMaxWidth}"
                            Margin="30,20"
                            HyperlinkClicked="MarkdownBox_OnHyperlinkClicked"
                            Markdown="{Binding CurrentMarkdown}"
                            MarkdownFontFamily="{Binding NovelFontFamilyObject}"
                            MarkdownFontSize="{Binding NovelFontSize}"
                            MarkdownFontWeight="{Binding NovelFontWeight}"
                            MarkdownForeground="{Binding NovelForegroundBrush}"
                            MarkdownLineHeight="{Binding NovelLineHeight}" />

                        <Grid Background="#7F000000" IsVisible="{Binding IsLoading}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">
                                <ProgressBar Width="160" IsIndeterminate="{Binding IsLoading}" />
                                <TextBlock Foreground="White" Text="{I18N {x:Static pixeval:EntryViewerPageResources.LoadingNovelTextBlockText}}" />
                            </StackPanel>
                        </Grid>

                        <Grid Background="#7F000000" IsVisible="{Binding LoadErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock
                                MaxWidth="480"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="{Binding LoadErrorMessage}"
                                TextWrapping="Wrap" />
                        </Grid>

                        <controls:PageButton
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Command="{Binding PrevCommand}"
                            ContextRequested="PrevButton_OnRightClick"
                            IsVisible="{Binding PrevButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="ChevronLeft"
                            ToolTipText="{Binding PrevButtonText}" />
                        <controls:PageButton
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Command="{Binding NextCommand}"
                            ContextRequested="NextButton_OnRightClick"
                            IsVisible="{Binding NextButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="ChevronRight"
                            ToolTipText="{Binding NextButtonText}" />
                    </Panel>
                </Border>
            </DockPanel>
        </SplitView>

        <ListBox
            Grid.Row="1"
            Height="90"
            Margin="5,0"
            Padding="0,0,0,5"
            HorizontalAlignment="Stretch"
            IsVisible="{Binding IsBottomListOpen}"
            ItemsSource="{Binding Novels}"
            SelectedIndex="{Binding CurrentWorkIndex}"
            SelectionMode="Single">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="5" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="{x:Type novel:NovelItemViewModel}">
                    <Image
                        Width="80"
                        Height="80"
                        controls:Source.Cache="{Binding ThumbnailUrl}"
                        Stretch="UniformToFill" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border
            Grid.Row="2"
            Height="48"
            Padding="5,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="20">
                    <CommandBar DefaultLabelPosition="Collapsed" IsDynamicOverflowEnabled="True">
                        <CommandBarToggleButton
                            Icon="{markup:SymbolIcon Info}"
                            IsChecked="{Binding #InfoSplitView.IsPaneOpen}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.InfoAndComments}}" />
                        <CommandBarToggleButton
                            Icon="{markup:SymbolIcon PanelBottomExpand}"
                            IsChecked="{Binding IsBottomListOpen}"
                            Label="{I18N {x:Static pixeval:MiscResources.OpenBottomList}}" />
                    </CommandBar>
                    <controls:IconText
                        MaxWidth="350"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        IsVisible="{Binding CurrentNovel.Entry.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue={x:Null}}"
                        Symbol="AppTitle"
                        Text="{Binding CurrentNovel.Entry.Title, FallbackValue={x:Null}}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="20">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        IsVisible="{Binding IsMultiPage}">
                        <Run Text="{Binding CurrentPageIndex, Mode=OneWay, Converter={x:Static converters:PixevalConverters.PlusOne}}" />
                        <Run Text="/" />
                        <Run Text="{Binding PageCount}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</views:IconContentPage>
