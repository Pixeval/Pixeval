<ContentPage
    x:Class="Pixeval.Views.Viewers.IllustrationViewerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Pixeval.Views.Viewers"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:ss="using:SmoothScroll.Avalonia.Controls"
    xmlns:viewers="using:Pixeval.ViewModels.Viewers"
    x:DataType="{x:Type viewers:IllustrationViewerPageViewModel}"
    Header="{Binding CurrentIllustration.Entry.Title}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="FloatingPaneBackgroundBrush">#DDFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="FloatingPaneDockedBackgroundBrush">#EEFFFFFF</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="FloatingPaneBackgroundBrush">#DD1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="FloatingPaneDockedBackgroundBrush">#EE1E1E1E</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Styles>
        <Style Selector="controls|FloatingPaneView#EntryViewerFloatingPaneView">
            <Setter Property="DockedPaneWidth" Value="360" />
            <Setter Property="FloatingPaneMargin" Value="16" />
            <Setter Property="FloatingPaneWidth" Value="360" />
            <Setter Property="PaneVerticalAlignment" Value="Top" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition
                        Easing="CubicEaseOut"
                        Property="DockProgress"
                        Duration="0:0:0.3"
                        Delay="0:0:0.1" />
                </Transitions>
            </Setter>

            <Style Selector="^ Border#FloatingPaneBorder">
                <Setter Property="Background" Value="{DynamicResource FloatingPaneBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Style>

            <Style Selector="^:docked">
                <Setter Property="PaneVerticalAlignment" Value="Top" />

                <Style Selector="^ Border#FloatingPaneBorder">
                    <Setter Property="Background" Value="{DynamicResource FloatingPaneDockedBackgroundBrush}" />
                    <Setter Property="CornerRadius" Value="0" />
                </Style>
            </Style>
        </Style>

        <!-- TODO: This is broken again, fix it later
         
        <Style Selector="local|SwipeImageViewer#ImageViewerPage">
            <Setter Property="ClipToBounds" Value="False" />

            <Style Selector="^ controls|SwipeControl#SwipeContent">
                <Setter Property="ClipToBounds" Value="False" />

                <Style Selector="^ local|SingleImageViewer">
                    <Setter Property="ClipToBounds" Value="False" />

                    <Style Selector="^ ss|ScrollView#ViewerScrollView">
                        <Setter Property="ClipToBounds" Value="False" />

                        <Style Selector="^ /template/ ss|ScrollPresenter#PART_ContentPresenter">
                            <Setter Property="ClipToBounds" Value="False" />
                        </Style>
                    </Style>
                </Style>
            </Style>
        </Style>-->
        
        <Style Selector="local|ContinuousImageViewer#ImageViewerPage">
            <Setter Property="ClipToBounds" Value="False" />

            <Style Selector="^ ss|ScrollView#ViewerScrollView">
                <Setter Property="ClipToBounds" Value="False" />

                <Style Selector="^ /template/ ss|ScrollPresenter#PART_ContentPresenter">
                    <Setter Property="ClipToBounds" Value="False" />
                </Style>
            </Style>
        </Style>

        <Style Selector="Border#FloatingToolbarPane">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border#FloatingToolbarPane.proximity">
            <Setter Property="Opacity" Value="0.5" />
        </Style>

        <Style Selector="Border#FloatingToolbarPane.close-proximity">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border#FloatingToolbarPane.temporary-visible">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </ContentPage.Styles>

    <ContentPage.Icon>
        <Image
            x:Name="LogoImage"
            Width="16"
            Height="16" />
    </ContentPage.Icon>

    <ContentPage.KeyBindings>
        <KeyBinding Command="{Binding PrevCommand}" Gesture="Left" />
        <KeyBinding Command="{Binding NextCommand}" Gesture="Right" />
        <KeyBinding Command="{Binding PrevWorkCommand}" Gesture="Up" />
        <KeyBinding Command="{Binding NextWorkCommand}" Gesture="Down" />
        <!--
            TODO: Avalonia的HotKeyManager监听的是逻辑树，在多Tab的时候会出问题，所以先用局部的KeyBinding顶一下
            需要等Avalonia行为改了，或者用其它workaround修复
            因为是局部的KeyBindings，目前快捷键需要焦点在该ContentPage内部才会激活
        -->
        <KeyBinding Command="{Binding #I.ImageViewer.PlayPauseCommand}" Gesture="Space" />
        <KeyBinding Command="{Binding #I.ImageViewer.CopyCommand}" Gesture="Ctrl+C" />
        <KeyBinding Command="{Binding #I.ImageViewer.SaveCommand}" Gesture="Ctrl+S" />
    </ContentPage.KeyBindings>

    <Grid>
        <!--  主体区域：FloatingPaneView + 图片查看器  -->
        <controls:FloatingPaneView
            x:Name="EntryViewerFloatingPaneView"
            Grid.Row="0"
            PaneVerticalAlignment="Top">
            <controls:FloatingPaneView.Pane>
                <Border Name="FloatingPaneBorder">
                    <Border.Transitions>
                        <Transitions>
                            <CornerRadiusTransition
                                Easing="CubicEaseOut"
                                Property="CornerRadius"
                                Duration="0:0:0.3"
                                Delay="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <local:IllustrationViewerInfoPane IsDocked="{Binding #EntryViewerFloatingPaneView.IsDocked, Mode=TwoWay}" />
                </Border>
            </controls:FloatingPaneView.Pane>
            <DockPanel>
                <Panel Background="Transparent">
                    <!--  图片查看器  -->

                    <local:ImageViewerWrapper
                        x:Name="I"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        DataContext="{Binding CurrentImage}"
                        SelectionChanged="ImageViewerPage_OnSelectionChanged" />

                    <!--  左翻页按钮  -->
                    <controls:PageButton
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Command="{Binding PrevCommand}"
                        RightTapped="PrevButton_OnRightClick"
                        Symbol="ChevronLeft"
                        ToolTipText="{Binding PrevButtonText}">
                        <controls:PageButton.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Converter="{x:Static StringConverters.IsNotNullOrEmpty}" Path="PrevButtonText" />
                                <Binding Path="#I.IsSwipeMode" />
                            </MultiBinding>
                        </controls:PageButton.IsVisible>
                    </controls:PageButton>

                    <!--  右翻页按钮  -->
                    <controls:PageButton
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Command="{Binding NextCommand}"
                        RightTapped="NextButton_OnRightClick"
                        Symbol="ChevronRight"
                        ToolTipText="{Binding NextButtonText}">
                        <controls:PageButton.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Converter="{x:Static StringConverters.IsNotNullOrEmpty}" Path="NextButtonText" />
                                <Binding Path="#I.IsSwipeMode" />
                            </MultiBinding>
                        </controls:PageButton.IsVisible>
                    </controls:PageButton>

                    <Border
                        x:Name="FloatingToolbarPane"
                        Margin="32"
                        Padding="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        controls:FloatingPane.IsEnabled="True"
                        Background="{DynamicResource SystemAltMediumHighColor}"
                        ClipToBounds="False"
                        CornerRadius="20">
                        <StackPanel Spacing="8">
                            <controls:PagePreviewSlider
                                Padding="5"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding CurrentImage.Images}"
                                SelectedIndex="{Binding CurrentPageIndex, Mode=TwoWay}">
                                <controls:PagePreviewSlider.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Type viewers:SingleViewerViewModel}">
                                        <Border
                                            MaxWidth="100"
                                            MaxHeight="96"
                                            ClipToBounds="True"
                                            CornerRadius="{StaticResource ControlCornerRadius}">
                                            <Image Source="{Binding ThumbnailSource}" Stretch="Uniform" />
                                        </Border>
                                    </DataTemplate>
                                </controls:PagePreviewSlider.ItemTemplate>
                            </controls:PagePreviewSlider>

                            <CommandBar
                                x:Name="ZoomPane"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Classes="floating-command-bar"
                                CornerRadius="0"
                                Theme="{StaticResource FloatingCommandBarTheme}">
                                <CommandBar.PrimaryCommands>
                                    <CommandBarButton
                                        Command="{Binding #I.SwipeImageViewer.RotateCounterclockwiseCommand, FallbackValue={x:Null}}"
                                        Content="{markup:SymbolIcon ArrowRotateCounterclockwise,
                                                                    FontSize=16}"
                                        IsVisible="{Binding #I.IsSwipeMode, Mode=OneTime}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:EntryViewerPageResources.RotateCounterclockwise}}" />
                                    <CommandBarToggleButton
                                        Command="{Binding #I.SwipeImageViewer.MirrorCommand, FallbackValue={x:Null}}"
                                        Content="{markup:SymbolIcon FlipHorizontal,
                                                                    FontSize=16}"
                                        IsChecked="{Binding #I.SwipeImageViewer.IsMirrored, Mode=TwoWay, FallbackValue={x:False}}"
                                        IsVisible="{Binding #I.IsSwipeMode, Mode=OneTime}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:EntryViewerPageResources.Mirror}}" />
                                    <CommandBarButton
                                        Command="{Binding #I.SwipeImageViewer.RotateClockwiseCommand, FallbackValue={x:Null}}"
                                        Content="{markup:SymbolIcon ArrowRotateClockwise,
                                                                    FontSize=16}"
                                        IsVisible="{Binding #I.IsSwipeMode, Mode=OneTime}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:EntryViewerPageResources.RotateClockwise}}" />
                                    <CommandBarSeparator x:Name="SwipeTransformSeparator" IsVisible="{Binding #I.IsSwipeMode, Mode=OneTime}" />
                                    <CommandBarButton
                                        Command="{Binding #I.ImageViewer.ZoomOutCommand}"
                                        Content="{markup:SymbolIcon ZoomOut,
                                                                    FontSize=16}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:EntryViewerPageResources.ZoomOut}}" />
                                    <controls:CommandBarElementContainer>
                                        <TextBlock x:Name="ZoomFactorTextBlock" Text="{Binding #I.ImageViewer.ZoomFactor, StringFormat={}{0:P0}}" />
                                    </controls:CommandBarElementContainer>
                                    <CommandBarButton
                                        Command="{Binding #I.ImageViewer.ZoomInCommand}"
                                        Content="{markup:SymbolIcon ZoomIn,
                                                                    FontSize=16}"
                                        ToolTip.Tip="{I18N {x:Static pixeval:EntryViewerPageResources.ZoomIn}}" />
                                    <CommandBarSeparator />
                                    <CommandBarButton
                                        Command="{Binding PrevCommand}"
                                        Content="{markup:SymbolIcon ChevronLeft,
                                                                    FontSize=16}"
                                        IsEnabled="{Binding PrevButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        RightTapped="PrevButton_OnRightClick"
                                        ToolTip.Tip="{Binding PrevButtonText}" />
                                    <CommandBarButton
                                        Command="{Binding NextCommand}"
                                        Content="{markup:SymbolIcon ChevronRight,
                                                                    FontSize=16}"
                                        IsEnabled="{Binding NextButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        RightTapped="NextButton_OnRightClick"
                                        ToolTip.Tip="{Binding NextButtonText}" />
                                </CommandBar.PrimaryCommands>
                            </CommandBar>
                        </StackPanel>
                    </Border>
                </Panel>
            </DockPanel>
        </controls:FloatingPaneView>
    </Grid>
</ContentPage>
