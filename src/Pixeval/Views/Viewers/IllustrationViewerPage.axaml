<UserControl
    x:Class="Pixeval.Views.Viewers.IllustrationViewerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Pixeval.Views.Viewers"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:viewModels="using:Pixeval.ViewModels"
    xmlns:viewers="using:Pixeval.ViewModels.Viewers"
    xmlns:work="using:Pixeval.Views.Work"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type viewers:IllustrationViewerPageViewModel}"
    mc:Ignorable="d">

    <UserControl.KeyBindings>
        <KeyBinding Command="{Binding PrevCommand}" Gesture="Left" />
        <KeyBinding Command="{Binding NextCommand}" Gesture="Right" />
        <KeyBinding Command="{Binding PrevIllustrationCommand}" Gesture="Up" />
        <KeyBinding Command="{Binding NextIllustrationCommand}" Gesture="Down" />
    </UserControl.KeyBindings>

    <Grid>
        <Grid RowDefinitions="*,Auto,Auto">
            <!--  主体区域：SplitView + 图片查看器  -->
            <SplitView
                x:Name="EntryViewerSplitView"
                Grid.Row="0"
                DisplayMode="Inline">
                <SplitView.Pane>
                    <TabbedPage Pages="{Binding PanePages}" />
                </SplitView.Pane>
                <DockPanel>
                    <!--  顶部工具栏  -->
                    <CommandBar
                        x:Name="TopBar"
                        HorizontalAlignment="Center"
                        DefaultLabelPosition="Collapsed"
                        DockPanel.Dock="Top">
                        <CommandBarButton
                            Command="{Binding CurrentImage.RotateCounterclockwiseCommand}"
                            Icon="{markup:SymbolIcon ArrowRotateCounterclockwise}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.RotateCounterclockwise}}" />
                        <CommandBarToggleButton
                            Icon="{markup:SymbolIcon FlipHorizontal}"
                            IsChecked="{Binding CurrentImage.IsMirrored}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.Mirror}}" />
                        <CommandBarButton
                            Command="{Binding CurrentImage.RotateClockwiseCommand}"
                            Icon="{markup:SymbolIcon ArrowRotateClockwise}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.RotateClockwise}}" />
                        <CommandBarSeparator />
                        <CommandBarButton
                            Command="{Binding CurrentPage.SaveCommand}"
                            CommandParameter="{Binding $self, Mode=OneTime}"
                            Icon="{markup:SymbolIcon Save}"
                            IsEnabled="{Binding CurrentImage.LoadSuccessfully}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.Save}}" />
                        <CommandBarButton
                            Command="{Binding CurrentPage.SaveAsCommand}"
                            CommandParameter="{Binding $self, Mode=OneTime}"
                            Icon="{markup:SymbolIcon SaveEdit}"
                            IsEnabled="{Binding CurrentImage.LoadSuccessfully}"
                            Label="{I18N {x:Static pixeval:EntryViewerPageResources.SaveAs}}" />
                        <CommandBarButton
                            Command="{Binding CurrentIllustration.SaveCommand}"
                            CommandParameter="{Binding $self, Mode=OneTime}"
                            Icon="{markup:SymbolIcon SaveMultiple}"
                            IsVisible="{Binding CurrentIllustration.IsPicSet}"
                            Label="{I18N {x:Static pixeval:EntryItemResources.MangaSave}}" />
                        <CommandBarSeparator />
                        <CommandBarButton
                            x:Name="AddToBookmarkButton"
                            Click="AddToBookmarkButton_OnClick"
                            Icon="{markup:SymbolIcon Bookmark}"
                            Label="{I18N {x:Static pixeval:MiscResources.AddBookmark}}" />
                        <CommandBarButton
                            Click="{x:Static utilities:AvaloniaHelper.CopyTagToClipboard}"
                            Icon="{markup:SymbolIcon LinkMultiple}"
                            Label="{I18N {x:Static pixeval:EntryItemResources.GenerateWebLink}}"
                            Tag="{Binding CurrentIllustration.WebsiteUri}" />
                        <CommandBarButton
                            Click="{x:Static utilities:AvaloniaHelper.LaunchUriTagInWebBrowser}"
                            Icon="{markup:SymbolIcon GlobeArrowUp}"
                            Label="{I18N {x:Static pixeval:EntryItemResources.OpenInWebBrowser}}"
                            Tag="{Binding CurrentIllustration.WebsiteUri}" />
                    </CommandBar>

                    <!--  BookmarkTagSelector（参考WorkContainer，另开一行显示）  -->
                    <work:TagSelector
                        x:Name="BookmarkTagSelector"
                        Margin="5"
                        DockPanel.Dock="Top"
                        IsVisible="False"
                        TagsSelected="BookmarkTagSelector_OnTagsSelected" />

                    <Panel Background="Transparent">
                        <!--  图片查看器  -->
                        <local:ImageViewerPage x:Name="ImageViewerPage" DataContext="{Binding CurrentImage}" />

                        <!--  左翻页按钮  -->
                        <Button
                            Width="50"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Click="PrevButton_OnClick"
                            IsVisible="{Binding PrevButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Opacity="0"
                            ToolTip.Tip="{Binding PrevButtonText}">
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                        </Transitions>
                                    </Setter>
                                </Style>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Style>
                            </Button.Styles>
                            <markup:SymbolIcon FontSize="24" Symbol="ChevronLeft" />
                        </Button>

                        <!--  右翻页按钮  -->
                        <Button
                            Width="50"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Click="NextButton_OnClick"
                            IsVisible="{Binding NextButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Opacity="0"
                            ToolTip.Tip="{Binding NextButtonText}">
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                        </Transitions>
                                    </Setter>
                                </Style>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Style>
                            </Button.Styles>
                            <markup:SymbolIcon FontSize="24" Symbol="ChevronRight" />
                        </Button>
                    </Panel>
                </DockPanel>
            </SplitView>

            <!--  缩略图列表  -->
            <ListBox
                x:Name="ThumbnailListBox"
                Grid.Row="1"
                Height="90"
                Margin="5,0"
                Padding="0,0,0,5"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsBottomListOpen}"
                ItemsSource="{Binding Illustrations}"
                SelectedIndex="{Binding CurrentIllustrationIndex}"
                SelectionMode="Single">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="{x:Type viewModels:IllustrationItemViewModel}">
                        <Image
                            Width="80"
                            Height="80"
                            Source="{Binding Thumbnail}"
                            Stretch="UniformToFill" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  底部状态栏  -->
            <Border
                Grid.Row="2"
                Height="48"
                Padding="5,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!--  左侧：信息面板/列表开关 + 标题  -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="20">
                        <CommandBar DefaultLabelPosition="Collapsed">
                            <CommandBarToggleButton
                                Icon="{markup:SymbolIcon Symbol=Info}"
                                IsChecked="{Binding #EntryViewerSplitView.IsPaneOpen}"
                                Label="{I18N {x:Static pixeval:EntryViewerPageResources.InfoAndComments}}" />
                            <CommandBarToggleButton
                                Icon="{markup:SymbolIcon Symbol=PanelBottomExpand}"
                                IsChecked="{Binding IsBottomListOpen}"
                                Label="{I18N {x:Static pixeval:MiscResources.OpenBottomList}}" />
                        </CommandBar>
                        <controls:IconText
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            IsVisible="{Binding CurrentIllustration.SizeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="SlideSize"
                            Text="{Binding CurrentIllustration.SizeText}" />
                        <controls:IconText
                            MaxWidth="200"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            IsVisible="{Binding CurrentIllustration.Entry.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="AppTitle"
                            Text="{Binding CurrentIllustration.Entry.Title}" />
                    </StackPanel>

                    <!--  右侧：页码 + 缩放  -->
                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="20">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            IsVisible="{Binding CurrentIllustration.IsPicSet}">
                            <!--  不加OneWay会调用ConvertBack，不知道为什么  -->
                            <Run Text="{Binding CurrentPageIndex, Mode=OneWay, Converter={x:Static local:IllustrationViewerPage.PlusOneConverter}}" />
                            <Run Text="/" />
                            <Run Text="{Binding PageCount}" />
                        </TextBlock>
                        <CommandBar DefaultLabelPosition="Collapsed">
                            <CommandBarButton
                                Click="ZoomOutButton_OnClick"
                                Icon="{markup:SymbolIcon ZoomOut}"
                                Label="{I18N {x:Static pixeval:EntryViewerPageResources.ZoomOut}}" />
                            <CommandBarButton
                                Click="ZoomInButton_OnClick"
                                Icon="{markup:SymbolIcon ZoomIn}"
                                Label="{I18N {x:Static pixeval:EntryViewerPageResources.ZoomIn}}" />
                        </CommandBar>
                        <TextBlock MinWidth="60" Text="{Binding #ImageViewerPage.ZoomFactor, StringFormat=P2, Mode=OneWay}">
                            <TextBlock.Theme>
                                <ControlTheme BasedOn="{StaticResource CaptionStrongTextBlockStyle}" TargetType="{x:Type TextBlock}">
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="Margin" Value="10,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Center" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </ControlTheme>
                            </TextBlock.Theme>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
