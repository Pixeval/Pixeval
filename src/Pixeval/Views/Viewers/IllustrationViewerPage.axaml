<ContentPage
    x:Class="Pixeval.Views.Viewers.IllustrationViewerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:FluentIcons.Common"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:converters="using:Pixeval.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Pixeval.Views.Viewers"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:markup1="using:Pixeval.Views.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:viewModels="using:Pixeval.ViewModels"
    xmlns:viewers="using:Pixeval.ViewModels.Viewers"
    xmlns:work="using:Pixeval.Views.Work"
    xmlns:ss="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type viewers:IllustrationViewerPageViewModel}"
    Header="{Binding CurrentIllustration.Entry.Title}"
    mc:Ignorable="d">

    <ContentPage.Styles>
        <Style Selector="controls|FloatingPaneView#EntryViewerFloatingPaneView">
            <Setter Property="PaneVerticalAlignment" Value="Bottom"></Setter>

            <Style Selector="^ Border#FloatingPaneBorder">
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Margin" Value="20" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Width" Value="400" />
                <Setter Property="Background" Value="#DDFFFFFF"></Setter>
            </Style>

            <Style Selector="^:docked">
                <Setter Property="PaneVerticalAlignment" Value="Stretch"></Setter>

                <Style Selector="^ Border#FloatingPaneBorder">
                    <Setter Property="VerticalAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="Width" Value="440" />
                    <Setter Property="Background" Value="#EEFFFFFF"></Setter>
                </Style>
            </Style>
        </Style>

        <Style Selector="local|ImageViewerPage#ImageViewerPage">
            <Setter Property="ClipToBounds" Value="False" />

            <Style Selector="^ ss|ScrollView#ZoomBorder">
                <Setter Property="ClipToBounds" Value="False" />

                <Style Selector="^ /template/ ss|ScrollPresenter#PART_ContentPresenter">
                    <Setter Property="ClipToBounds" Value="False" />
                </Style>
            </Style>
        </Style>


    </ContentPage.Styles>

    <ContentPage.Icon>
        <Image
            x:Name="LogoImage"
            Width="16"
            Height="16" />
    </ContentPage.Icon>

    <ContentPage.KeyBindings>
        <KeyBinding Command="{Binding PrevCommand}" Gesture="Left" />
        <KeyBinding Command="{Binding NextCommand}" Gesture="Right" />
        <KeyBinding Command="{Binding PrevWorkCommand}" Gesture="Up" />
        <KeyBinding Command="{Binding NextWorkCommand}" Gesture="Down" />
        <!-- TODO: Avalonia的HotKeyManager监听的是逻辑树，在多Tab的时候会出问题，所以先用局部的KeyBinding顶一下
                需要等Avalonia行为改了，或者用其它workaround修复
                因为是局部的KeyBindings，目前快捷键需要焦点在该ContentPage内部才会激活 -->
        <KeyBinding Command="{Binding CurrentImage.PlayPauseCommand}" Gesture="Space" />
        <KeyBinding Command="{Binding CurrentImage.CopyCommand}"
                    CommandParameter="{Binding $parent[local:IllustrationViewerPage], Mode=OneTime}" Gesture="Ctrl+C" />
        <KeyBinding Command="{Binding CurrentPage.SaveCommand}"
                    CommandParameter="{Binding $parent[local:IllustrationViewerPage], Mode=OneTime}" Gesture="Ctrl+S" />
    </ContentPage.KeyBindings>

    <Grid>
        <Grid RowDefinitions="*,Auto,Auto">
            <!--  主体区域：FloatingPaneView + 图片查看器  -->
            <controls:FloatingPaneView
                x:Name="EntryViewerFloatingPaneView"
                Grid.Row="0">
                <controls:FloatingPaneView.Pane>
                    <Border Name="FloatingPaneBorder">
                        <local:IllustrationViewerInfoPane IsDocked="{Binding #EntryViewerFloatingPaneView.IsDocked, Mode=TwoWay}" />
                    </Border>
                </controls:FloatingPaneView.Pane>
                <DockPanel>
                    <!--  BookmarkTagSelector  -->
                    <work:TagSelector
                        x:Name="BookmarkTagSelector"
                        Margin="5"
                        DockPanel.Dock="Top"
                        IsVisible="False"
                        TagsSelected="BookmarkTagSelector_OnTagsSelected" />

                    <Panel Background="Transparent" controls:FloatingPaneHost.IsEnabled="True">
                        <!--  图片查看器  -->
                        <local:ImageViewerPage x:Name="ImageViewerPage" DataContext="{Binding CurrentImage}"
                                               ZoomChanged="ImageViewerPage_OnZoomChanged" />

                        <!--  左翻页按钮  -->
                        <controls:PageButton
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Command="{Binding PrevCommand}"
                            IsVisible="{Binding PrevButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            RightTapped="PrevButton_OnRightClick"
                            Symbol="ChevronLeft"
                            ToolTipText="{Binding PrevButtonText}" />

                        <!--  右翻页按钮  -->
                        <controls:PageButton
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Command="{Binding NextCommand}"
                            IsVisible="{Binding NextButtonText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            RightTapped="NextButton_OnRightClick"
                            Symbol="ChevronRight"
                            ToolTipText="{Binding NextButtonText}" />

                        <controls:ZoomIndicator
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            x:Name="ZoomPane"
                            controls:FloatingPane.IsEnabled="True" />
                    </Panel>
                </DockPanel>
            </controls:FloatingPaneView>

            <!--  缩略图列表  -->
            <ListBox
                x:Name="ThumbnailListBox"
                Grid.Row="1"
                Height="90"
                Margin="5,0"
                Padding="0,0,0,5"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsBottomListOpen}"
                ItemsSource="{Binding Illustrations}"
                SelectedIndex="{Binding CurrentWorkIndex}"
                SelectionMode="Single">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="{x:Type viewModels:IllustrationItemViewModel}">
                        <Image
                            Width="80"
                            Height="80"
                            controls:Source.Cache="{Binding ThumbnailUrl}"
                            Stretch="UniformToFill" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  底部状态栏  -->
            <Border
                IsVisible="False"
                Grid.Row="2"
                Height="48"
                Padding="5,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!--  左侧：信息面板/列表开关 + 标题  -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="20">
                        <CommandBar DefaultLabelPosition="Collapsed" IsDynamicOverflowEnabled="True">
                            <CommandBarToggleButton
                                Icon="{markup:SymbolIcon Info}"
                                IsChecked="{Binding #EntryViewerFloatingPaneView.IsDocked}"
                                Label="{I18N {x:Static pixeval:EntryViewerPageResources.InfoAndComments}}" />
                            <CommandBarToggleButton
                                Icon="{markup:SymbolIcon PanelBottomExpand}"
                                IsChecked="{Binding IsBottomListOpen}"
                                Label="{I18N {x:Static pixeval:MiscResources.OpenBottomList}}" />
                        </CommandBar>
                        <controls:IconText
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            IsVisible="{Binding CurrentIllustration.SizeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="SlideSize"
                            Text="{Binding CurrentIllustration.SizeText}" />
                        <controls:IconText
                            MaxWidth="200"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            IsVisible="{Binding CurrentIllustration.Entry.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Symbol="AppTitle"
                            Text="{Binding CurrentIllustration.Entry.Title}" />
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
