<SplitView
    x:Class="Pixeval.Views.Viewers.WorkViewerSplitView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pixeval.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utilities="using:Pixeval.Utilities"
    xmlns:viewers="using:Pixeval.Views.Viewers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <SplitView.Pane>
        <TabControl ItemsSource="{Binding $parent[viewers:WorkViewerSplitView].MenuItemsSource}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <DataTemplate.DataType>
                        <x:Type x:TypeArguments="x:Double" TypeName="utilities:NavigationInfo" />
                    </DataTemplate.DataType>
                    <controls:IconText Symbol="{Binding Icon}" Text="{Binding Header}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <DataTemplate.DataType>
                        <x:Type x:TypeArguments="x:Double" TypeName="utilities:NavigationInfo" />
                    </DataTemplate.DataType>
                    <ContentControl Content="{Binding Icon}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </SplitView.Pane>
</SplitView>
