<ContentPage
    x:Class="Pixeval.Views.Login.LoginPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markup="using:FluentIcons.Avalonia.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pixeval="using:Pixeval"
    xmlns:viewModels="using:Pixeval.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type viewModels:LoginPageViewModel}"
    Header="{I18N {x:Static pixeval:MainPageResources.LoginTabContent}}"
    Icon="{markup:SymbolIcon PersonKey,
                             FontSize=16,
                             IconVariant=Color}"
    mc:Ignorable="d">
    <ContentPage.DataContext>
        <viewModels:LoginPageViewModel />
    </ContentPage.DataContext>
    <DockPanel>
        <StackPanel
            Width="300"
            Margin="50"
            VerticalAlignment="Center"
            DockPanel.Dock="Right"
            IsEnabled="{Binding !#WebView.IsVisible}"
            Spacing="10">
            <!--  本地化字符串  -->
            <TextBox
                x:Name="TextBox"
                HorizontalAlignment="Stretch"
                PlaceholderText="Refresh Token" />
            <Button
                HorizontalAlignment="Stretch"
                Click="LoginButton_OnClick"
                Content="RefreshToken Log in" />
            <Button
                HorizontalAlignment="Stretch"
                Click="OpenWebView_OnClick"
                Content="WebView Log in" />
        </StackPanel>
        <NativeWebView x:Name="WebView" IsVisible="False" />
    </DockPanel>
</ContentPage>
